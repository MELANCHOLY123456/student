# ========================================
# 学生成绩管理系统 - 环境变量配置模板
# ========================================
# 说明：将此文件复制为 .env，然后填入您的实际配置
# WARNING: .env 文件包含敏感信息，DO NOT commit to Git!

# ========================================
# 数据库配置
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=sgs_user
DB_PASSWORD=your_strong_password_here
DB_NAME=student_grade_system
DB_CHARSET=utf8mb4

# ========================================
# 应用配置
# ========================================
# 是否启用调试模式 (True/False)
DEBUG=False

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log
